# ── LLM ────────────────────────────────────────────────────────────────────
# Absolute path to the quantized GGUF model file (e.g., /models/qwen3-4b-instruct-2507.Q4_K_M.gguf)
MODEL_PATH=/absolute/path/to/your/model.gguf

# Absolute path to the directory containing the three tokenizer JSON files
TOKENIZER_PATH=/absolute/path/to/tokenizer/dir

# Total context window the model supports (tokens)
MODEL_MAX_CONTEXT=8192

# Token budget allocated to conversation history.
# Leaves headroom for the system prompt + generated response.
CHAT_HISTORY_TOKEN_BUDGET=6144

# CPU threads allocated to llama.cpp inference
N_THREADS=8

# GPU layers to offload. 0 = CPU-only. -1 = offload all (requires CUDA build).
# Defaulting to 0 for maximum compatibility during review.
N_GPU_LAYERS=0

# Hard cap on tokens the model can generate per response
MAX_NEW_TOKENS=2048

# Stop tokens for llama.cpp (comma-separated). Match EOS tokens from training.
# LLM_STOP_TOKENS=<|im_end|>,<|endoftext|>

# Chat template Jinja2 string (fallback for tokenizers missing chat_template in tokenizer_config.json).
# LLM_CHAT_TEMPLATE=...

# Set to true ONLY for Qwen3 models when you want visible chain-of-thought reasoning.
# LLM_ENABLE_THINKING=false

# ── Database ────────────────────────────────────────────────────────────────
# Use your local PostgreSQL credentials here
DB_URL=postgresql+asyncpg://db_user:db_password@localhost:5432/chatbot

# ── Auth / JWT ───────────────────────────────────────────────────────────────
# Never commit this value to git.
# You can generate one using: openssl rand -hex 32
SECRET_KEY=your_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── App ─────────────────────────────────────────────────────────────────────
DEBUG=false
API_PREFIX=/api

# The origins/URLs that the API will be able to receive requests from (frontend).
ALLOWED_ORIGINS=http://localhost:5173

# ── Logging (Optional) ──────────────────────────────────────────────────────
# LOG_LEVEL=INFO
# LOG_DIR=logs